---
import type { GetStaticPaths } from "astro";
import { languages, buildLocaleUrl } from "../../lib/i18n";
import PageLayout from "../../layouts/PageLayout.astro";
import { Mail } from "@lucide/astro";
export const getStaticPaths = (() => {
  const localeLinks = languages.map((lang) => ({
    lang,
    href: buildLocaleUrl(lang, "/"),
  }));
  return languages.map((lang) => ({
    params: { lang },
    props: { localeLinks },
  }));
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const { localeLinks } = Astro.props;

const t = {
  zh: {
    name: "刘仁钦",
    description:
      "你好，我是刘仁钦，<strong>浙江大学</strong>27届<strong>计算机科学与技术专业</strong>本科生。",
  },
  en: {
    name: "Renqin Liu",
    description:
      "Hi, I'm Renqin Liu, undergraduate student majoring in <strong>Computer Science and Technology</strong> at <strong>Zhejiang University</strong>, Class of 2027.",
  },
}[lang];
---

<PageLayout lang={lang} localeLinks={localeLinks}>
  <h1>{t.name}</h1>
  <p set:html={t.description} />
  <p>
    Email: liurenqin [AT] zju.edu.cn<br />
    GitHub: <a
      href="https://github.com/cyrus28214"
      target="_blank"
      rel="noopener noreferrer">cyrus28214</a
    >
  </p>
</PageLayout>
