---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MilestoneView from "../../views/MilestoneView.astro";
import LinksView from "../../views/LinksView.astro";
import ProfileView from "../../views/ProfileView.astro";
import { getCollection } from "astro:content";

export const getStaticPaths = (async () => {
  const blogs = await getCollection("blog");
  const blogPaths = blogs.map((blog) => `blogs/${blog.data.slug}`);
  // undefined 代表 /en /zh 这样的根路径
  const paths = [undefined, "milestone", "links", ...blogPaths];
  console.log(paths);
  const langs = ["en", "zh"];
  return langs.flatMap((lang) =>
    paths.map((path) => ({ params: { lang, path } })),
  );
}) satisfies GetStaticPaths;

const { lang, path } = Astro.params;
---

<BaseLayout lang={lang} url={path ?? ""}>
  {path === "milestone" && <MilestoneView lang={lang} />}
  {path === "links" && <LinksView lang={lang} />}
  {path === undefined && <ProfileView lang={lang} />}
</BaseLayout>
