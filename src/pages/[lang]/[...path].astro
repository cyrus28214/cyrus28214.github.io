---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MilestoneView from "../../views/MilestoneView.astro";
import LinksView from "../../views/LinksView.astro";
import ProfileView from "../../views/ProfileView.astro";
import BlogPostView from "../../views/BlogPostView.astro";
import { getCollection } from "astro:content";

const blogPrefix = "blog/";

export const getStaticPaths = (async () => {
  const blogs = await getCollection("blog");
  const blogPaths = blogs.map((blog) => blogPrefix + blog.data.slug);
  // undefined 代表 /en /zh 这样的根路径
  const paths = [undefined, "links", "milestone", ...blogPaths];
  console.log(paths);
  const langs = ["en", "zh"];
  return langs.flatMap((lang) =>
    paths.map((path) => ({ params: { lang, path } })),
  );
}) satisfies GetStaticPaths;

const { lang, path } = Astro.params;
const blogSlug = path?.startsWith(blogPrefix)
  ? path.slice(blogPrefix.length)
  : null;
---

<BaseLayout lang={lang} url={path ?? ""}>
  {path === "milestone" && <MilestoneView lang={lang} />}
  {path === "links" && <LinksView lang={lang} />}
  {path === undefined && <ProfileView lang={lang} />}
  {blogSlug && <BlogPostView lang={lang} slug={blogSlug} />}
</BaseLayout>
