---
import { getCollection, render, getEntry } from "astro:content";
import {
  mustParseLanguage,
  languages,
  buildLocaleUrl,
  type LanguageKey,
} from "../../../lib/i18n";
import PageLayout from "../../../layouts/PageLayout.astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog", ({ data }) => {
    return import.meta.env.DEV || !data.draft;
  });

  return blogEntries.map((entry) => {
    return {
      params: {
        lang: entry.data.lang,
        id: entry.data.id, // 业务 ID
      },
      props: { entry },
    };
  });
}

const { lang: langParam, id: idParam } = Astro.params;
const lang = mustParseLanguage(langParam);

// 1. 尝试获取当前语言的条目
// 注意：在你的 loader 中，id 被存储为 `${lang}/${data.id}`
let blog = await getEntry("blog", `${lang}/${idParam}`);
let isFallback = false;

// 2. 如果当前语言版本不存在，执行 Fallback 逻辑
if (!blog) {
  const allEntries = await getCollection("blog");
  // 寻找业务 ID 相同但语言不同的条目
  const availableVersions = allEntries.filter((e) => e.data.id === idParam);

  if (availableVersions.length === 0) {
    throw new Error(`[Blog] Not found: ${idParam}`);
  }

  // 按照 i18n 配置的语言顺序寻找第一个可用的 fallback
  const fallbackLang = languages.find((l) =>
    availableVersions.some((v) => v.data.lang === l),
  );
  blog = availableVersions.find((v) => v.data.lang === fallbackLang)!;
  isFallback = true;
}

// 3. 获取所有可用的语言版本用于切换（排除当前正在显示的实际语言）
const allRelated = await getCollection("blog", (e) => e.data.id === idParam);
const otherVersions = allRelated.filter((e) => e.data.lang !== blog.data.lang);

// 4. 渲染 Markdown 内容
const { Content } = await render(blog);
const { data } = blog;

const dateLocale = lang === "zh" ? "zh-CN" : "en-US";
const formatDate = (d: Date) =>
  new Intl.DateTimeFormat(dateLocale, { dateStyle: "long" }).format(d);

const t = {
  zh: {
    back: "← 返回博客列表",
    updated: "更新于",
    fallbackNotice: "本文暂无中文版本，正在显示其他语言版本。",
    otherLangs: "其他语言版本：",
  },
  en: {
    back: "← Back to blog",
    updated: "Updated",
    fallbackNotice: "No English version available, showing other language.",
    otherLangs: "Other languages:",
  },
}[lang];

const langLabel: Record<string, string> = {
  zh: "中文",
  en: "English",
};
---

<PageLayout lang={lang}>
  <nav class="back-nav">
    <a href={buildLocaleUrl(lang, "/blog")}>{t.back}</a>
  </nav>

  <article class="post">
    {isFallback && <p class="fallback-notice">{t.fallbackNotice}</p>}

    {
      data.cover && (
        <div class="cover">
          {/* 如果你的 schema 使用了 image()，这里建议直接传 data.cover */}
          <img
            src={typeof data.cover === "string" ? data.cover : data.cover.src}
            alt=""
          />
        </div>
      )
    }

    <header class="post-header">
      <h1 lang={data.lang}>{data.title}</h1>
      {
        data.description && (
          <p class="description" lang={data.lang}>
            {data.description}
          </p>
        )
      }
      <div class="meta">
        <time datetime={data.created_at.toISOString()}>
          {formatDate(data.created_at)}
        </time>
        {
          data.updated_at && (
            <span class="updated">
              · {t.updated}{" "}
              <time datetime={data.updated_at.toISOString()}>
                {formatDate(data.updated_at)}
              </time>
            </span>
          )
        }
      </div>
    </header>

    <div class="post-body" lang={data.lang}>
      <Content />
    </div>
  </article>

  {
    otherVersions.length > 0 && (
      <footer class="post-footer">
        <span class="other-langs-label">{t.otherLangs}</span>
        {otherVersions.map((v) => (
          <a
            class="other-lang"
            href={buildLocaleUrl(
              v.data.lang as LanguageKey,
              `/blog/${idParam}`,
            )}
            lang={v.data.lang}
          >
            {langLabel[v.data.lang] || v.data.lang}
          </a>
        ))}
      </footer>
    )
  }
</PageLayout>

<style>
  .back-nav {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .back-nav a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .back-nav a:hover {
    color: var(--text-color);
    text-decoration: underline;
  }

  .fallback-notice {
    margin: 0 0 1.5rem;
    padding: 0.6rem 1rem;
    border-left: 3px solid var(--primary-color);
    background-color: var(--bg-muted, rgba(125, 125, 125, 0.1));
    color: var(--text-muted);
    font-size: 0.9rem;
    border-radius: 4px;
  }

  .cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 10px;
    margin-bottom: 1.5rem;
    background-color: var(--bg-muted, rgba(125, 125, 125, 0.08));
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.5rem;
  }

  .description {
    color: var(--text-muted);
    margin: 0 0 1rem;
    font-size: 1.1rem;
    line-height: 1.5;
  }

  .meta {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .updated {
    margin-left: 0.25rem;
  }

  /* 针对文章内容的样式微调 */
  .post-body {
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .other-langs-label {
    margin-right: 0.25rem;
  }

  .other-lang {
    padding: 0.2rem 0.65rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--text-color);
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }

  .other-lang:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
  }
</style>
