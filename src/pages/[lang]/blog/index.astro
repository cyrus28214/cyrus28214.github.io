---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import { languages, buildLocaleUrl } from "../../../lib/i18n";
import PageLayout from "../../../layouts/PageLayout.astro";
import BlogCard from "../../../components/BlogCard.astro";

export const getStaticPaths = (() => {
  const localeLinks = languages.map((lang) => ({
    lang,
    href: buildLocaleUrl(lang, "/blog"),
  }));
  return languages.map((lang) => ({
    params: { lang },
    props: { localeLinks },
  }));
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const { localeLinks } = Astro.props;

const items = (
  await getCollection("blog", ({ data }) => {
    return import.meta.env.DEV || !data.draft;
  })
)
  .filter((entry) => entry.data.lang == lang)
  .sort((a, b) => b.data.created_at.getTime() - a.data.created_at.getTime());

const t = {
  zh: {
    title: "博客",
    empty: "暂无文章",
  },
  en: {
    title: "Blog",
    empty: "No Posts Yet",
  },
}[lang];
---

<PageLayout lang={lang} localeLinks={localeLinks}>
  <h1>{t.title}</h1>
  {
    items.length === 0 ? (
      <p class="empty">{t.empty}</p>
    ) : (
      <div class="blog-grid">
        {items.map((item) => (
          <BlogCard entry={item} />
        ))}
      </div>
    )
  }
</PageLayout>

<style>
  .empty {
    color: var(--text-muted);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
</style>
