---
import { getCollection, render } from "astro:content";
import {
  buildLocaleUrl,
  formatDate,
  langLabel,
  type LanguageKey,
} from "../../../lib/i18n";
import PostToc from "../../../components/PostToc.astro";
import PageLayout from "../../../layouts/PageLayout.astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog", ({ data }) => {
    return import.meta.env.DEV || !data.draft;
  });

  const groupMap = new Map<string, Record<LanguageKey, string>>();

  for (const entry of blogEntries) {
    const groupId = entry.data.localeGroupId;
    let group = groupMap.get(groupId);
    if (!group) {
      group = {} as Record<LanguageKey, string>;
      group[entry.data.lang] = entry.data.slug;
      groupMap.set(groupId, group);
    } else {
      group[entry.data.lang] = entry.data.slug;
    }
  }

  return blogEntries.map((entry) => {
    const groupId = entry.data.localeGroupId;
    let group = groupMap.get(groupId) ?? ({} as Record<LanguageKey, string>);
    group[entry.data.lang] = entry.data.slug;
    let localeLinks = Object.entries(group).map(([lang, slug]) => ({
      lang: lang as LanguageKey,
      href: buildLocaleUrl(lang as LanguageKey, `/blog/${slug}`),
    }));
    return {
      params: {
        lang: entry.data.lang,
        slug: entry.data.slug,
      },
      props: { blog: entry, localeLinks },
    };
  });
}

const { lang } = Astro.params;
const { blog, localeLinks } = Astro.props;
const otherLangs = localeLinks.filter((l) => l.lang != lang);

const { Content, headings } = await render(blog);
const { data } = blog;

const t = {
  zh: {
    back: "← 返回博客列表",
    updated: "更新于",
    fallbackNotice: "本文暂无中文版本，正在显示其他语言版本。",
    otherLangs: "其他语言版本：",
    toc: "目录",
    licenseText:
      '除特别说明外，本文采用 <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noreferrer">CC BY-NC-SA 4.0</a> 协议发布。转载请注明出处，禁止商业使用，演绎作品需采用相同协议共享。',
  },
  en: {
    back: "← Back to blog",
    updated: "Updated",
    fallbackNotice: "No English version available, showing other language.",
    otherLangs: "Other languages:",
    toc: "Contents",
    licenseText:
      'Unless otherwise noted, this article is licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noreferrer">CC BY-NC-SA 4.0</a> Please provide attribution, do not use it commercially, and share adaptations under the same license.',
  },
}[lang];
---

<PageLayout lang={lang} localeLinks={localeLinks}>
  <nav class="back-nav">
    <a href={buildLocaleUrl(lang, "/blog")}>{t.back}</a>
  </nav>

  <article class="post">
    {
      data.cover && (
        <div class="cover">
          {/* 如果你的 schema 使用了 image()，这里建议直接传 data.cover */}
          <img
            src={typeof data.cover === "string" ? data.cover : data.cover.src}
            alt=""
          />
        </div>
      )
    }

    <header class="post-header">
      <h1 lang={data.lang}>{data.title}</h1>
      {
        data.description && (
          <p class="description" lang={data.lang}>
            {data.description}
          </p>
        )
      }
      <div class="meta">
        <time datetime={data.created_at.toISOString()}>
          {formatDate(lang, data.created_at)}
        </time>
        {
          data.updated_at && (
            <span class="updated">
              · {t.updated}{" "}
              <time datetime={data.updated_at.toISOString()}>
                {formatDate(lang, data.updated_at)}
              </time>
            </span>
          )
        }
      </div>
      {
        otherLangs.length > 0 && (
          <div class="post-locales">
            <span class="other-langs-label">{t.otherLangs}</span>
            {otherLangs.map((l) => (
              <a class="other-lang" href={l.href}>
                {langLabel[l.lang]}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <PostToc headings={headings} title={t.toc} />

    <div class="post-body" lang={data.lang}>
      <Content />
    </div>
  </article>

  <footer class="post-footer">
    <section class="post-license" aria-labelledby="post-license-title">
      <p set:html={t.licenseText} />
    </section>
  </footer>
</PageLayout>

<style>
  .back-nav {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .post-locales {
    margin-top: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .back-nav a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .back-nav a:hover {
    color: var(--text-color);
    text-decoration: underline;
  }

  .cover {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    margin-bottom: 1.5rem;
    background-color: var(--bg-muted, rgba(125, 125, 125, 0.08));
  }

  .cover img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .post-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.5rem;
  }

  .description {
    color: var(--text-muted);
    margin: 0 0 1rem;
    font-size: 1.1rem;
    line-height: 1.5;
  }

  .meta {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .updated {
    margin-left: 0.25rem;
  }

  /* 针对文章内容的样式微调 */
  .post-body {
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .post-footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .other-langs-label {
    margin-right: 0.25rem;
  }

  .other-lang {
    padding: 0.2rem 0.65rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--text-color);
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }

  .other-lang:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
  }

  @media (min-width: 641px) {
    .post-license-head {
      align-items: center;
      flex-direction: row;
      gap: 0;
    }
  }
</style>
