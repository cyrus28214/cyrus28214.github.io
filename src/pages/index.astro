---
const fallbackLocale = "/zh/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <title>Redirecting...</title>
    <link rel="canonical" href={fallbackLocale} />
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${fallbackLocale}`} />
    </noscript>
  </head>
  <body>
    <script is:inline>
      const preferredLanguages = Array.isArray(navigator.languages)
        ? navigator.languages
        : [navigator.language];

      const targetLocale = preferredLanguages.some((lang) =>
        lang?.toLowerCase().startsWith("zh"),
      )
        ? "/zh/"
        : "/en/";

      const suffix = `${window.location.search}${window.location.hash}`;
      window.location.replace(`${targetLocale}${suffix}`);
    </script>
    <p>
      Redirecting…
      <a href={fallbackLocale}>Continue to the site</a>
    </p>
  </body>
</html>
