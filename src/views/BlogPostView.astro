---
import type { CollectionEntry } from "astro:content";
import { languages, type LanguageKey } from "../i18n";
import PageLayout from "../layouts/PageLayout.astro";

interface Props {
  blog: CollectionEntry<"blog">;
  lang: LanguageKey; // 期望的语言，blog不一定有对应语言，没有的时候行为是 fallback
}

const { blog, lang: expectedLang } = Astro.props;
const versions = blog.data.versions;
const candidates = Object.keys(versions) as LanguageKey[];

let actualLang: LanguageKey;
if (candidates.includes(expectedLang)) {
  actualLang = expectedLang;
} else {
  // 按 languages 的定义顺序 fallback，前面的优先级高
  const fallback = languages.find((l) => candidates.includes(l));
  if (!fallback) {
    throw new Error(`No available version for blog "${blog.id}"`);
  }
  actualLang = fallback;
}

const version = versions[actualLang];
const isFallback = actualLang !== expectedLang;

const dateLocale = expectedLang === "zh" ? "zh-CN" : "en-US";
const formatDate = (d: Date) =>
  new Intl.DateTimeFormat(dateLocale, { dateStyle: "long" }).format(d);

const t = {
  zh: {
    updated: "更新于",
    fallbackNotice: `本文暂无中文版本`,
  },
  en: {
    updated: "Updated",
    fallbackNotice: `No English version available`,
  },
}[expectedLang];
---

<PageLayout>
  <article class="post">
    {
      isFallback && (
        <p class="fallback-notice" lang={expectedLang}>
          {t.fallbackNotice}
        </p>
      )
    }
    <header class="post-header" lang={actualLang}>
      <h1>{version.title}</h1>
      {version.description && <p class="description">{version.description}</p>}
      <div class="meta">
        <time datetime={version.created_at.toISOString()}>
          {formatDate(version.created_at)}
        </time>
        {
          version.updated_at && (
            <span class="updated">
              · {t.updated}{" "}
              <time datetime={version.updated_at.toISOString()}>
                {formatDate(version.updated_at)}
              </time>
            </span>
          )
        }
      </div>
    </header>
    <div class="post-content" lang={actualLang} set:html={version.html} />
  </article>
</PageLayout>

<style>
  .fallback-notice {
    margin: 0 0 1.5rem;
    padding: 0.6rem 1rem;
    border-left: 3px solid var(--primary-color);
    background-color: var(--bg-muted, rgba(125, 125, 125, 0.1));
    color: var(--text-muted);
    font-size: 0.9rem;
    border-radius: 4px;
  }

  .post-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.5rem;
  }

  .post-header h1 {
    font-size: 2.5rem;
    margin: 0 0 0.75rem;
    color: var(--text-color);
  }

  .description {
    color: var(--text-muted);
    margin: 0 0 1rem;
    font-size: 1.1rem;
    line-height: 1.5;
  }

  .meta {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .updated {
    margin-left: 0.25rem;
  }

  .post-content {
    line-height: 1.7;
    color: var(--text-color);
  }

  .post-content :global(h2) {
    font-size: 1.75rem;
    margin: 2.5rem 0 1rem;
  }

  .post-content :global(h3) {
    font-size: 1.4rem;
    margin: 2rem 0 0.75rem;
  }

  .post-content :global(p) {
    margin: 1rem 0;
  }

  .post-content :global(a) {
    color: var(--primary-color);
    text-decoration: underline;
  }

  .post-content :global(a:hover) {
    opacity: 0.8;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5rem;
    margin: 1rem 0;
  }

  .post-content :global(li) {
    margin: 0.35rem 0;
  }

  .post-content :global(blockquote) {
    margin: 1.25rem 0;
    padding: 0.5rem 1rem;
    border-left: 3px solid var(--primary-color);
    color: var(--text-muted);
    background-color: var(--bg-muted, transparent);
  }

  .post-content :global(code) {
    background-color: var(--bg-muted, rgba(125, 125, 125, 0.15));
    padding: 0.15rem 0.35rem;
    border-radius: 4px;
    font-size: 0.92em;
  }

  .post-content :global(pre) {
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    background-color: var(--bg-muted, rgba(125, 125, 125, 0.1));
  }

  .post-content :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
  }

  .post-content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1.25rem 0;
  }

  .post-content :global(th),
  .post-content :global(td) {
    border: 1px solid var(--border-color);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .post-content :global(hr) {
    border: 0;
    border-top: 1px solid var(--border-color);
    margin: 2rem 0;
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 2rem;
    }
  }
</style>
