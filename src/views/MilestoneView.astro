---
interface Milestone {
  date: string;
  content: string;
}

interface Props {
  title: string;
  milestones: Milestone[];
}

const { title, milestones } = Astro.props;
---

<div class="page-container">
  <h1>{title}</h1>
  <div class="timeline">
    {
      milestones.map((item) => (
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-body">
            <div class="timeline-date">{item.date}</div>
            <div class="timeline-content" set:html={item.content} />
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: var(--text-color);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    display: flex;
    gap: 2rem;
  }

  /* 标记（点和线）所在的区域 */
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 12px; /* 控制整个列的宽度为点的宽度 */
    flex-shrink: 0;
  }

  /* 实心圆点 */
  .timeline-marker::before {
    content: "";
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--primary-color);
    margin-top: 0.4rem; /* 向下稍微偏移以对齐文字的中心或顶部 */
  }

  /* 连接线（非最后一个节点时） */
  .timeline-item:not(:last-child) .timeline-marker::after {
    content: "";
    width: 2px;
    flex-grow: 1;
    background-color: var(--border-color);
    margin-top: 0.5rem; /* 线和点之间的距离 */
    margin-bottom: -3rem; /* 向下延伸填满间隙 (抵消 gap 和 额外的高度) */
  }

  .timeline-body {
    flex-grow: 1;
  }

  .timeline-date {
    font-weight: bold;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  .timeline-content {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .timeline-content :global(a) {
    color: var(--primary-color);
    text-decoration: underline;
  }

  .timeline-content :global(a:hover) {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .timeline-item {
      gap: 1.5rem;
    }
  }
</style>
