---
import assert from "node:assert/strict";

interface Props {
  lang: string;
}

const translations = {
  en: {
    title: "Milestone",
    milestones: [
      {
        date: "2026.05.06",
        content:
          "Website new look, using a minimalist Astro template developed by myself",
      },
      {
        date: "2025.06.06",
        content:
          "Website new look, migrated to Astro and using <a href='https://github.com/saicaca/fuwari' target='_blank' rel='noopener noreferrer'>saicaca/fuwari</a> as a template",
      },
      {
        date: "2024.04.01",
        content: "Completed ICP filing",
      },
      {
        date: "2024.03.30",
        content: "Enabled domain codecyrus.com",
      },
      {
        date: "2024.03.29",
        content: "Changed VPS provider from Tencent Cloud to Alibaba Cloud",
      },
      {
        date: "2023.08.29",
        content: "Enabled domain cyrus28214.top",
      },
      {
        date: "2023.07.05",
        content: "Replaced Github Pages backend with Tencent Cloud VPS",
      },
      {
        date: "2023.06.29",
        content: "Built website with Hexo and Github Pages",
      },
    ],
  },
  zh: {
    title: "大事记",
    milestones: [
      {
        date: "2026.05.06",
        content: "网站 new look，使用自己开发的简约风 Astro 模版",
      },
      {
        date: "2025.06.06",
        content:
          "网站 new look，迁移到Astro并使用 <a href='https://github.com/saicaca/fuwari' target='_blank' rel='noopener noreferrer'>saicaca/fuwari</a> 作为模版",
      },
      {
        date: "2024.04.01",
        content: "完成 ICP 备案",
      },
      {
        date: "2024.03.30",
        content: "启用域名 codecyrus.com",
      },
      {
        date: "2024.03.29",
        content: "VPS 服务商从腾讯云更换到阿里云",
      },
      {
        date: "2023.08.29",
        content: "启用域名 cyrus28214.top",
      },
      {
        date: "2023.07.05",
        content: "更换 Github Pages 后端为腾讯云 VPS",
      },
      {
        date: "2023.06.29",
        content: "用 Hexo 和 Github Pages 建站",
      },
    ],
  },
};

const { lang } = Astro.props;
assert(lang in translations);
const t = translations[lang as keyof typeof translations];
---

<div class="page-container">
  <h1>{t.title}</h1>
  <div class="timeline">
    {
      t.milestones.map((item) => (
        <div class="timeline-item">
          <div class="timeline-marker" />
          <div class="timeline-body">
            <div class="timeline-date">{item.date}</div>
            <div class="timeline-content" set:html={item.content} />
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: var(--text-color);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    display: flex;
    gap: 2rem;
  }

  /* 标记（点和线）所在的区域 */
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 12px; /* 控制整个列的宽度为点的宽度 */
    flex-shrink: 0;
  }

  /* 实心圆点 */
  .timeline-marker::before {
    content: "";
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--primary-color);
    margin-top: 0.4rem; /* 向下稍微偏移以对齐文字的中心或顶部 */
  }

  /* 连接线（非最后一个节点时） */
  .timeline-item:not(:last-child) .timeline-marker::after {
    content: "";
    width: 2px;
    flex-grow: 1;
    background-color: var(--border-color);
    margin-top: 0.5rem; /* 线和点之间的距离 */
    margin-bottom: -3rem; /* 向下延伸填满间隙 (抵消 gap 和 额外的高度) */
  }

  .timeline-body {
    flex-grow: 1;
  }

  .timeline-date {
    font-weight: bold;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  .timeline-content {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .timeline-content :global(a) {
    color: var(--primary-color);
    text-decoration: underline;
  }

  .timeline-content :global(a:hover) {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .timeline-item {
      gap: 1.5rem;
    }
  }
</style>
