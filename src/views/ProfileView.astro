---
import assert from "node:assert/strict";
interface Props {
  lang: string;
}

const translations = {
  en: {
    title: "Profile",
    content: "Hello! Welcome to my profile page.",
  },
  zh: {
    title: "个人主页",
    content: "你好！欢迎来到我的个人主页。",
  },
};

const { lang } = Astro.props;

assert(lang in translations);
const t = translations[lang as keyof typeof translations];
---

<div class="profile-container">
  <h1>{t.title}</h1>
  <div class="profile-content">
    <p>{t.content}</p>
  </div>
</div>

<style>
  .profile-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: var(--text-color);
  }

  .profile-content {
    line-height: 1.6;
    color: var(--text-muted);
  }
</style>
