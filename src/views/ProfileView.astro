---
interface Props {
  title: string;
  content: string;
}

const { title, content } = Astro.props;
---

<div class="profile-container">
  <h1>{title}</h1>
  <div class="profile-content">
    <p>{content}</p>
  </div>
</div>

<style>
  .profile-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-color);
  }
  
  .profile-content {
    line-height: 1.6;
    color: var(--text-muted);
  }
</style>
