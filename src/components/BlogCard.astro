---
import type { CollectionEntry } from "astro:content";
import { buildLocaleUrl, formatDate } from "../lib/i18n";
import Card from "./Card.astro";
import { Image } from "astro:assets";

interface Props {
  entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props;
const { data } = entry;
const t = {
  zh: {
    updated: "更新于",
    fallback: "其他语言",
    draft: "草稿",
  },
  en: {
    updated: "Updated",
    fallback: "Other language",
    draft: "Draft",
  },
}[data.lang];
---

<Card href={buildLocaleUrl(data.lang, `/blog/${data.slug}`)}>
  <div class:list={["blog-card", { "has-cover": !!data.cover }]}>
    <div class="content">
      <h2 class="title">{data.title}</h2>
      {data.description && <p class="description">{data.description}</p>}
      <div class="meta">
        <time datetime={data.created_at.toISOString()}>
          {formatDate(data.lang, data.created_at)}
        </time>
        {
          data.updated_at && (
            <span class="updated">
              · {t.updated}{" "}
              <time datetime={data.updated_at.toISOString()}>
                {formatDate(data.lang, data.updated_at)}
              </time>
            </span>
          )
        }
        <div class="badges">
          {data.draft && <span class="badge">{t.draft}</span>}
        </div>
      </div>
    </div>
    {
      data.cover && (
        <div class="cover">
          {typeof data.cover === "object" ? (
            <Image src={data.cover} alt={data.title} width={800} height={600} />
          ) : (
            <img src={data.cover} alt="" loading="lazy" />
          )}
        </div>
      )
    }
  </div>
</Card>

<style>
  .blog-card {
    min-width: 0;
  }

  .blog-card.has-cover {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(180px, 30%, 320px);
    align-items: stretch;
  }

  .blog-card:hover .title {
    text-decoration: underline;
  }

  .blog-card:hover .cover img {
    transform: scale(1.02);
  }

  .cover {
    grid-column: 2;
    grid-row: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-color: var(--bg-muted, rgba(125, 125, 125, 0.08));
    border-left: 1px solid var(--border-color);
  }

  .cover :global(picture) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .cover img,
  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    border-radius: 0;
    transition: transform 0.3s ease;
  }

  .content {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
    padding: 1.2rem 1.4rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .title {
    font-size: 1.35rem;
    line-height: 1.4;
    color: var(--text-color);
    margin: 0;
  }

  .description {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }

  .updated {
    color: var(--text-muted);
  }

  .badges {
    display: inline-flex;
    gap: 0.4rem;
    margin-left: auto;
  }

  .badge {
    display: inline-block;
    padding: 0.05rem 0.55rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    font-size: 0.72rem;
    color: var(--text-muted);
    background-color: var(--bg-color);
  }

  @media (max-width: 768px) {
    .blog-card.has-cover {
      grid-template-columns: minmax(0, 1fr) minmax(140px, 34%);
    }

    .content {
      padding: 1rem 1.1rem 1.1rem;
    }

    .title {
      font-size: 1.15rem;
    }

    .description {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 520px) {
    .blog-card.has-cover {
      grid-template-columns: minmax(0, 1fr) minmax(120px, 36%);
    }

  }
</style>
