---
import ThemeToggle from "./ThemeToggle.astro";
import LanguagePicker from "./LanguagePicker.astro";
import { Image } from "astro:assets";
import logoImage from "../assets/logo.png";
import { getRelativeLocaleUrl } from "astro:i18n";
import type { LanguageKey } from "../lib/i18n";

interface Props {
  lang: LanguageKey;
  localeLinks: {
    lang: LanguageKey;
    href: string;
  }[];
  logoHref: string; // url no locale prefix
}

const { lang, logoHref, localeLinks } = Astro.props;
---

<nav class="navbar">
  <div class="logo-container">
    <a href={logoHref} class="logo-link">
      <Image
        src={logoImage}
        alt="CodeCyrus Logo"
        class="logo-img"
        width={120}
        height={120}
      />
      <div class="logo-text">
        <span class="logo-title">CodeCyrus</span>
        <span class="logo-subtitle">Think twice, code once.</span>
      </div>
    </a>
  </div>
  <div class="nav-links">
    <slot />
    <LanguagePicker lang={lang} localeLinks={localeLinks} />
    <ThemeToggle />
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background-color: var(--bg-color);
    border-bottom: 1px solid var(--border-color);
  }

  .logo-container {
    display: flex;
    align-items: center;
  }

  .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--text-color);
    gap: 0.75rem;
  }

  .logo-img {
    border-radius: 50%;
    width: 40px;
    height: 40px;
    object-fit: cover;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .logo-title {
    font-weight: bold;
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .logo-subtitle {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.2;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 1rem;
    }
    .logo-subtitle {
      display: none;
    }
    .nav-links {
      gap: 1rem;
    }
  }
</style>
