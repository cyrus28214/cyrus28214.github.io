---
import Navbar from "../components/Navbar.astro";
import NavLink from "../components/NavLink.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import "../styles/global.css";
import "../styles/variables.css";
import assert from "node:assert/strict";
import { buildLocaleUrl, type LanguageKey } from "../lib/i18n";

interface Props {
  lang: LanguageKey;
}

const { lang } = Astro.props;

const navItems = {
  en: [
    { name: "profile", text: "Profile", href: "/" },
    { name: "blog", text: "Blog", href: "/blog" },
    { name: "links", text: "Links", href: "/links" },
    { name: "milestone", text: "Milestone", href: "/milestone" },
  ],
  zh: [
    { name: "profile", text: "个人主页", href: "/" },
    { name: "blog", text: "博客", href: "/blog" },
    { name: "links", text: "朋友们", href: "/links" },
    { name: "milestone", text: "大事记", href: "/milestone" },
  ],
}[lang];

const pathname = Astro.url.pathname;
const activeItem = navItems.find((item) => {
  const fullHref = buildLocaleUrl(lang, item.href);
  // 特殊判断首页，不然会全部匹配上
  if (item.href === "/") {
    return pathname === fullHref || pathname === `${fullHref}/`;
  }
  return pathname.startsWith(fullHref);
});

const activeNav = activeItem?.name || null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon/favicon-16x16.png"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@200..900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.45/dist/katex.min.css"
      integrity="sha384-UA8juhPf75SzzAMA/4fo3yOU7sBJ0om7SCD2GHq0fZqZco6tr1UCV7nUbk9J90JM"
      crossorigin="anonymous"
    />
    <meta name="generator" content={Astro.generator} />
    <title>CodeCyrus - Think twice, code once.</title>
    <script is:inline>
      const setDarkMode = () => {
        const theme = (() => {
          if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
          ) {
            return localStorage.getItem("theme");
          }
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            return "dark";
          }
          return "light";
        })();
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
        window.localStorage.setItem("theme", theme);
      };

      setDarkMode();
      document.addEventListener("astro:after-swap", setDarkMode);
    </script>
  </head>
  <body>
    <Navbar logoHref={buildLocaleUrl(lang, "/")} lang={lang}>
      {
        navItems.map((item) => (
          <NavLink
            href={buildLocaleUrl(lang, item.href)}
            isActive={activeNav === item.name}
          >
            {item.text}
          </NavLink>
        ))
      }
    </Navbar>
    <main>
      <slot />
    </main>
  </body>
</html>
<style>
  html,
  body {
    width: 100%;
    height: 100%;
  }
</style>
