---
// 通用页面内容容器：统一 max-width / padding / 颜色 / 响应式
---

<div class="page-container">
  <slot />
</div>

<style>
  .page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    color: var(--text-color);
  }

  @media (max-width: 768px) {
    .page-container {
      padding: 1.5rem 1rem;
    }
  }

  @media (min-width: 1600px) {
    .page-container {
      max-width: 880px;
    }
  }
</style>
