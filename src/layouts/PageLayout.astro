---
import type { LanguageKey } from "../lib/i18n";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  lang: LanguageKey;
}

const { lang } = Astro.props;
---

<BaseLayout lang={lang}>
  <div class="page-container">
    <slot />
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem;
  }
</style>
